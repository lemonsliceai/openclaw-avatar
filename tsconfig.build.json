{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "avatar/index.ts",
    "avatar/sidecar-process-control.ts",
    "types/**/*.d.ts"
  ]
}
